{
  "name": "ats-task",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "replay": "tsx tools/replay/src/index.ts",
    "db:migrate": "tsx --tsconfig packages/persistence/tsconfig.build.json packages/persistence/src/cli/migrate.ts",
    "db:seed": "tsx --tsconfig packages/persistence/tsconfig.build.json packages/persistence/src/cli/seed.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0"
  }
}
